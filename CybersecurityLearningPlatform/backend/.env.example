# Flask 設定
FLASK_ENV=development
FLASK_DEBUG=True
FLASK_PORT=5000
SHOW_DEBUG_ANSWERS=false

# LLM provider：openai、groq、lm_studio 或 nvidia
LLM_PROVIDER=lm_studio

# OpenAI-compatible 本機伺服器；LLM_PROVIDER=lm_studio 時使用
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_MODEL=openai/gpt-oss-20b

# 實驗腳本使用的聊天端點
LM_STUDIO_CHAT_URL=http://127.0.0.1:1234/v1/chat/completions
LM_STUDIO_CHAT_URL_ALT=http://127.0.0.1:1234/v1/chat/completions

# 實驗腳本使用的 embedding 端點
EMBEDDING_BASE_URL=http://127.0.0.1:1234/v1

# OpenAI；LLM_PROVIDER=openai 時使用
OPENAI_API_KEY=

# Google GenAI / Gemini；ETL 萃取腳本使用
GOOGLE_API_KEY=
GEMINI_API_KEY=

# Groq；LLM_PROVIDER=groq 與部分實驗腳本使用
GROQ_API_KEY=
GROQ_API_KEY_1=
GROQ_API_KEY_2=
GROQ_MODEL=llama3-70b-8192

# NVIDIA；LLM_PROVIDER=nvidia 與驗證腳本使用
NVIDIA_API_KEY_1=
NVIDIA_API_KEY_2=
NVIDIA_API_KEY_3=
NVIDIA_API_KEY_4=
NVIDIA_API_KEY_5=
NVIDIA_API_KEY_6=
NVIDIA_MODEL=meta/llama-3.3-70b-instruct

# Neo4j 設定
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# --- 資料路徑 ---
SOURCE_DATA_DIR=SourceData
CHUNKS_DIR=Chunks
